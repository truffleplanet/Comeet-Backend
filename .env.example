SPRING_PROFILES_ACTIVE=dev
APP_PROFILE=dev

# MySQL
DEV_DB_URL=jdbc:mysql://<host>:3306/<database>?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DEV_DB_USERNAME=<db-username>
DEV_DB_PASSWORD=<db-password>

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TIMEOUT=60000

# CORS
CORS_ALLOWED_ORIGINS=https://<frontend-domain>,https://<admin-domain>

# JWT
JWT_SECRET=<strong-jwt-secret-at-least-32-bytes>
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=1209600000

# AI
OPENAI_API_KEY=<openai-api-key>
GEMINI_API_KEY=<gemini-api-key>
GEMINI_AI_MODEL=gemini-2.0-flash

# AWS S3
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
AWS_S3_BUCKET=<aws-s3-bucket>

# Optional app metadata
APP_NAME=Comeet
APP_VERSION=1.0.0
